<div class="form-grid">
  <label>Job category<input name="job_category" value="<%= job.job_category || '' %>" placeholder="e.g. Tech" required></label>
  <label>Designation<input name="job_designation" value="<%= job.job_designation || '' %>" placeholder="e.g. Backend Developer" required></label>
  <label>Company name<input name="company_name" value="<%= job.company_name || '' %>" required></label>
  <label>Location<input name="job_location" value="<%= job.job_location || '' %>" required></label>
  <label>Salary<input name="salary" value="<%= job.salary || '' %>" placeholder="e.g. 10-14 LPA" required></label>
  <label>Apply by<input type="date" name="apply_by" value="<%= job.apply_by || '' %>" required></label>
  <label>Number of openings<input type="number" name="number_of_openings" min="1" value="<%= job.number_of_openings || 1 %>" required></label>
  <label class="wide">Skills required<input name="skills_required" value="<%= job.skills_required || '' %>" placeholder="JavaScript, Node.js, Express" required></label>
  <label class="wide">Job description<textarea name="description" rows="6" required><%= job.description || '' %></textarea></label>
</div>
