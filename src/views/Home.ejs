<section class="hero">
  <p class="eyebrow">CAREERS, WITHOUT THE CLUTTER</p>
  <h1>Find work that feels like a step forward.</h1>
  <p>Explore fresh opportunities, apply in minutes, or find the next great person for your team.</p>
  <div class="actions"><a class="btn" href="/jobs">Explore jobs</a><a class="btn secondary" href="/jobs/new">Post a job</a></div>
</section>

<section class="section">
  <div class="section-heading"><div><p class="eyebrow">FEATURED</p><h2>Roles worth a look</h2></div><a href="/jobs">View all jobs →</a></div>
  <div class="card-grid">
    <% featuredJobs.forEach((job) => { %>
      <article class="job-card"><span class="tag"><%= job.job_category %></span><h3><%= job.job_designation %></h3><p><%= job.company_name %> · <%= job.job_location %></p><a href="/jobs/<%= job.id %>">View details →</a></article>
    <% }) %>
  </div>
</section>
