<section class="detail-hero">
  <div><span class="tag"><%= job.job_category %></span><h1><%= job.job_designation %></h1><p><%= job.company_name %> · <%= job.job_location %></p></div>
  <% if (user && job.recruiterId === user.id) { %><div class="actions"><a class="btn secondary" href="/jobs/<%= job.id %>/edit">Edit job</a><a class="btn" href="/jobs/<%= job.id %>/applicants">View applicants (<%= job.applicants.length %>)</a></div><% } %>
</section>
<div class="detail-grid">
  <article class="panel prose"><h2>About the role</h2><p><%= job.description %></p><h2>Skills required</h2><p><%= job.skills_required %></p></article>
  <aside>
    <div class="panel facts"><h2>Job overview</h2><dl><div><dt>Salary</dt><dd><%= job.salary %></dd></div><div><dt>Openings</dt><dd><%= job.number_of_openings %></dd></div><div><dt>Apply by</dt><dd><%= new Date(job.apply_by + 'T00:00:00').toLocaleDateString() %></dd></div></dl></div>
    <form class="panel form apply-form" action="/jobs/<%= job.id %>/apply" method="POST" enctype="multipart/form-data">
      <h2>Apply now</h2><%- include('../partials/errors', { errors: applicationErrors }) %>
      <label>Full name<input name="name" value="<%= applicationValues.name || '' %>" required></label>
      <label>Email<input type="email" name="email" value="<%= applicationValues.email || '' %>" required></label>
      <label>Contact number<input name="contact" value="<%= applicationValues.contact || '' %>" required></label>
      <label>Resume <small>PDF, DOC or DOCX · max 5 MB</small><input type="file" name="resume" accept=".pdf,.doc,.docx" required></label>
      <button class="btn" type="submit">Submit application</button>
    </form>
  </aside>
</div>
